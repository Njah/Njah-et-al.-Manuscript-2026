```{r setup, include=FALSE}

library(clusterProfiler)
library(org.Fvesca.eg.db)
library(readxl)
library(svglite)
library(tidyverse)
library(RColorBrewer)

```

```{r setup, include=FALSE}

######Section A: GO enrichment for significant DEGs#### 
#######       A.1 Alta crown
###1. Read DEG csv file for Alta crown####

Sig_DEG_AK <- read.csv("Sig_DEG_AK.csv", header = F,sep=",")

class(Sig_DEG_AK)

##Convert DEG object from dataframe to character
'Sig_DEG_AK' <- as.character(Sig_DEG_AK[,1])

##Check if object is character
class(Sig_DEG_AK)

head(Sig_DEG_AK)

####Molecular function enrichment

EnrichGO_DEG_AK <- enrichGO(Sig_DEG_AK,
                    'org.Fvesca.eg.db',
                    pvalueCutoff=0.01,
                    qvalueCutoff =0.1,
                    pAdjustMethod="BH",
                    keyType = "GID",
                    ont="ALL"
                   )

#####reduce redundancy of GO enriched terms

EnrichGO_DEG_AK_redun <- clusterProfiler::simplify(EnrichGO_DEG_AK,cutoff = 0.7, by = "p.adjust",select_fun = min,measure = "Wang",semData = NULL)

#####Extract results

head(EnrichGO_DEG_AK_redun@result)


##Since R identifies the GeneRatio, as character and not numeric, we need to format results to convert Ratio to fraction

EnrichGO_DEG_AK_redun.df <- EnrichGO_DEG_AK_redun@result %>%
  
  ##Separate ratios into 2 columns of data
  separate(BgRatio, into = c("size.term", "size.category"), sep = "/") %>%
  separate(GeneRatio, into = c("size.overlap.term", "size.overlap.category"),            sep = "/") %>%
  ##Convert to numeric
  mutate_at(vars("size.term", "size.category",
                 "size.overlap.term","size.overlap.category"),as.numeric) %>%
  ###Calculate k/K
  mutate(k.k=size.overlap.term/size.term)

View(EnrichGO_DEG_AK_redun.df)

###Export enrichment results

write.csv(EnrichGO_DEG_AK_redun.df, "EnrichGO_DEG_AK_redun.df.csv")

##### Visualize significant MF enrichment with FDR threshold set t 0.05 and Y-axis to Description

EnrichGO_DEG_AK_redun_FDR_0.05 <- EnrichGO_DEG_AK_redun.df %>% 
  filter(p.adjust <= 0.05) %>%
  
 ggplot(aes(x=Count, #Reorder gene sets by k/K values
               y=Description,fill=p.adjust)) +
    geom_col() +scale_color_gradient(low="blue", high="red")
theme_classic() +
  #Some more customization to pretty it up
  #fix labels
  labs(y="Number of Genes",
       x="GO Name",
       title = "AK enriched DEGs")

EnrichGO_DEG_AK_redun_FDR_0.05 <- EnrichGO_DEG_AK_redun_FDR_0.05 + theme(panel.background = element_blank())
EnrichGO_DEG_AK_redun_FDR_0.05

##Export plot
ggsave('EnrichGO_DEG_AK_redun_FDR_0.05.svg', width=8.0, height=4.0, plot=EnrichGO_DEG_AK_redun_FDR_0.05, device = "svg", path="./", dpi=600)

```

